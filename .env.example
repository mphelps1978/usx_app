# Dockploy — usxicbooks.cloud @ 72.61.75.55
# Copy values into each service in Dockploy (DB / API / frontend build args).

# =============================================================================
# DNS (at your registrar — both A records → 72.61.75.55)
# =============================================================================
#   usxicbooks.cloud      → 72.61.75.55   (frontend)
#   api.usxicbooks.cloud  → 72.61.75.55   (API)

# =============================================================================
# 1) Database (Dockploy PostgreSQL template)
# =============================================================================
POSTGRES_USER=usx
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=usx

# API connects using Dockploy’s internal DB hostname (example — use your service name):
# DATABASE_URL=postgresql://usx:PASSWORD@usx-db:5432/usx

# =============================================================================
# 2) Backend API  —  Dockerfile: api/Dockerfile  —  expose port 3001
#     Dockploy domain: api.usxicbooks.cloud
#
# Dockploy: add under API service → Environment (RUNTIME, not Build Args).
# Key must be exactly: DATABASE_URL  (all caps — not Database_URL)
# Value example (use internal DB hostname from Dockploy, not your PC):
#   postgresql://usx:PASSWORD@your-postgres-service-name:5432/usx
# Do NOT set PG_USE_WINDOWS_HOST on the server.
# Redeploy after saving env vars.
# =============================================================================
JWT_SECRET=change-me-long-random
DATABASE_URL=postgresql://usx:PASSWORD@usx-db:5432/usx
DATABASE_SSL=false
NODE_ENV=production
TRUST_PROXY=true
# Do not set DB_SYNC_ALTER=true on production unless you know the DB has no orphan rows
RECEIPTS_DIR=/data/receipts

FRONTEND_URL=https://usxicbooks.cloud
DEPLOYMENT_DOMAIN=usxicbooks.cloud
# Until HTTPS/DNS works, optional:
# ALLOWED_ORIGINS=http://72.61.75.55
# ALLOW_HTTP_ORIGINS=true

# Volume mount on API service: /data/receipts

# =============================================================================
# 3) Frontend  —  Dockerfile: interface/Dockerfile  —  expose port 80
#     Dockploy domain: usxicbooks.cloud
#     Build arg (required):
# =============================================================================
# VITE_API_URL=https://api.usxicbooks.cloud/api
